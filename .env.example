# Copy this file to .env and fill in your real values.
# .env is gitignored.

# Required for the OpenAI provider. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# Optional: point the OpenAI SDK at an OpenAI-compatible gateway (read automatically
# by the SDK). The default model in config/model_config.json
# (openai/gpt-oss-20b:free) is an OpenRouter slug, so set this to use it:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: only required if you wire up the Anthropic provider.
# ANTHROPIC_API_KEY=sk-ant-replace-me
